# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# prod-only: set to the canonical production origin, e.g. https://app.example.com

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM / compiler ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- TTS (prod uses elevenlabs; selfhost is local/CI only) ---
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICES_API_KEY=
ELEVENLABS_STOCK_VOICE_ID=
ELEVENLABS_STOCK_VOICE_MALE=
ELEVENLABS_STOCK_VOICE_FEMALE=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_CLONE_MODEL_ID=eleven_multilingual_v2

# --- Sentry (error tracking; optional locally) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time only — source map upload; omit locally so builds still succeed.
SENTRY_AUTH_TOKEN=

# --- Local seed only (never set in Vercel prod) ---
DEV_USER_PASSWORD=

# --- Inngest ---
# Local: set INNGEST_DEV=1 and run the Inngest Dev Server (no cloud keys needed).
INNGEST_DEV=1
# prod-only: leave INNGEST_DEV unset; set keys from Inngest Cloud / Vercel integration.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Stripe ---
# Use test keys (sk_test_… / whsec_… from `stripe listen`) locally.
# prod-only: live keys (sk_live_…), live Price IDs, and the Dashboard webhook signing secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TOPUP=
STRIPE_PRICE_GUIDED=
STRIPE_PRICE_PRACT=
